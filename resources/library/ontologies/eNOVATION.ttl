@prefix : <http://www.semanticweb.org/eNOVATION-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/eNOVATION-ontology#> .

<http://www.semanticweb.org/eNOVATION-ontology#> rdf:type owl:Ontology ;
                                                  rdfs:comment "The TC (Training Centres) eNOVATION Domain-Specific Ontology, aims to represent the accumulated knowledge on training centre capabilities, the services offered, and their interdependencies."@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty ;
                                               rdfs:comment "The range of skos:altLabel is the class of RDF plain literals."@en ,
                                                            "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               rdfs:label "alternative label"@en ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "An alternative lexical label for a resource."@en ;
                                               <http://www.w3.org/2004/02/skos/core#example> "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)."@en .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "definition"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A statement or formal explanation of the meaning of a concept."@en .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              rdfs:label "example"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "An example of the use of a concept."@en .


###  http://www.w3.org/2004/02/skos/core#scopeNote
<http://www.w3.org/2004/02/skos/core#scopeNote> rdf:type owl:AnnotationProperty ;
                                                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                rdfs:label "scope note"@en ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "A note that helps to clarify the meaning and/or the use of a concept."@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/eNOVATION-ontology#addressesThreat
:addressesThreat rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isAddressedBy ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :EmergencyResponsePlan
                                             :Resource
                                           )
                             ] ;
                 rdfs:range :ThreatAgent ;
                 rdfs:comment "Property to connect a resource to the threat agent it addresses"@en ;
                 rdfs:label "addresses threat"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#collaboratesWith
:collaboratesWith rdf:type owl:ObjectProperty ;
                  rdfs:domain :Organisation ;
                  rdfs:range :TrainingCentre ;
                  rdfs:comment "Property that connects an Organization with a Training Centre it works with"@en ;
                  rdfs:label "collaborates with"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#compliesWithStandard
:compliesWithStandard rdf:type owl:ObjectProperty ;
                      owl:inverseOf :isStandardCompliedWithBy ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( :ExternalLaboratorySupportService
                                                  :SOP
                                                  :TrainingCourse
                                                )
                                  ] ;
                      rdfs:range :Standard ;
                      rdfs:comment "Property to indicate with which standard an external laboratory service complies with"@en ;
                      rdfs:label "complies with Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#connectsWithNetwork
:connectsWithNetwork rdf:type owl:ObjectProperty ;
                     owl:inverseOf :isNetworkConnectedTo ;
                     rdfs:domain :TrainingCentre ;
                     rdfs:range :CBRNNetwork ;
                     rdfs:comment "Property to connect a training centre to its relative network"@en ;
                     rdfs:label "connects with network"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#earlyWarningForThreat
:earlyWarningForThreat rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isThreatWithEarlyWarning ;
                       rdfs:domain :EarlyWarning ;
                       rdfs:range :ThreatAgent ;
                       rdfs:comment "Property to connect an early warning response to the respective threat agent"@en ;
                       rdfs:label "early warning for threat"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#employsDecomMethod
:employsDecomMethod rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isDecomMethodEmployedBy ;
                    rdfs:domain :DecontaminationTechnology ;
                    rdfs:range :DecontaminationMethod ;
                    rdfs:comment "Property to connect a decontamination technology with the employed method"@en ;
                    rdfs:label "employs decontamination method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#engagesWithStakeholders
:engagesWithStakeholders rdf:type owl:ObjectProperty ;
                         owl:inverseOf :isStakeholderEngagedBy ;
                         rdfs:domain [ rdf:type owl:Class ;
                                       owl:unionOf ( :TrainingCentre
                                                     :TrainingCourse
                                                   )
                                     ] ;
                         rdfs:range :OrganisationalStakeholder ;
                         rdfs:comment "Property to indicate with which stakeholders a training centre engages"@en ;
                         rdfs:label "engages with stakeholders"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#followsSOP
:followsSOP rdf:type owl:ObjectProperty ;
            owl:inverseOf :isSOPFollowedBy ;
            rdfs:domain :ResponseAction ;
            rdfs:range :SOP ;
            rdfs:comment "property to show what SOP follows a response action"@en ;
            rdfs:label "follows SOP"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#grantsCertificate
:grantsCertificate rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isCertificateGrantedFor ;
                   rdfs:domain :TrainingCourse ;
                   rdfs:range :Certificate ;
                   rdfs:comment "Property to indicate the certificate granted by a training course"@en ;
                   rdfs:label "grants certificate"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasActorType
:hasActorType rdf:type owl:ObjectProperty ;
              owl:inverseOf :isActorTypeOf ;
              rdfs:domain :Exercise ;
              rdfs:range :ActorType ;
              rdfs:comment "This property specifies what type of actor a scenario role uses."@en ;
              rdfs:label "has actor type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasAffiliation
:hasAffiliation rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                owl:inverseOf :isAffiliationOf ;
                rdfs:domain :Person ;
                rdfs:range :PersonAffiliation ;
                rdfs:comment "Property used  to indicate the corresponding affiliation of a person or a group"@en ;
                rdfs:label "has affiliation"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasCapacity
:hasCapacity rdf:type owl:ObjectProperty ;
             owl:inverseOf :isCapacityOf ;
             rdfs:domain :TrainingCentre ;
             rdfs:range :Capacity ;
             rdfs:comment "Property to connect a Training centre to its capacity"@en ;
             rdfs:label "has capacity"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasCompetence
:hasCompetence rdf:type owl:ObjectProperty ;
               owl:inverseOf :isCompetenceOf ;
               rdfs:domain :TrainingCentre ;
               rdfs:range :Competence ;
               rdfs:comment "Property to connect a training centre to its competence"@en ;
               rdfs:label "has competence"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasDomainOfUse
:hasDomainOfUse rdf:type owl:ObjectProperty ;
                owl:inverseOf :isDomainOfUseOf ;
                rdfs:domain :Technology ;
                rdfs:range :DomainOfUse ;
                rdfs:comment "Property to connect a technology to its domain of use"@en ;
                rdfs:label "has domain of use"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasERPcapability
:hasERPcapability rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isERPCapabilityOf ;
                  rdfs:domain :EmergencyResponsePlan ;
                  rdfs:range :ERPCapability ;
                  rdfs:comment "Property to connect ERP class to ERP capability"@en ;
                  rdfs:label "has ERP capability"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasEquipment
:hasEquipment rdf:type owl:ObjectProperty ;
              owl:inverseOf :isEquipmentOf ;
              rdfs:domain :Organisation ;
              rdfs:range :Equipment ;
              rdfs:comment "Property to connect an organization (training centre) to its equipment"@en ;
              rdfs:label "has equipment"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasExerciseEvaluation
:hasExerciseEvaluation rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isExerciseEvaluationOf ;
                       rdfs:domain :Exercise ;
                       rdfs:range :ExerciseEvaluation ;
                       rdfs:comment "Property to connect an exercise with its evaluation"@en ;
                       rdfs:label "has exercise evaluation"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasExercisePhase
:hasExercisePhase rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isExercisePhaseOf ;
                  rdfs:domain :Exercise ;
                  rdfs:range :ExercisePhase ;
                  rdfs:comment "Property to connect an exercise with the phase the centre has knowledge"@en ;
                  rdfs:label "has exercise phase"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasExerciseType
:hasExerciseType rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isExerciseTypeOf ;
                 rdfs:domain :Exercise ;
                 rdfs:range :ExerciseType ;
                 rdfs:comment "Property to connect an exercise with its type"@en ;
                 rdfs:label "has exercise type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasExtraCapability
:hasExtraCapability rdf:type owl:ObjectProperty ;
                    owl:inverseOf :isExtraCapabilityOf ;
                    rdfs:domain :TrainingCentre ;
                    rdfs:range :ExtraCapability ;
                    rdfs:comment "Property to connect a training centre to its extra capabilities"@en ;
                    rdfs:label "has extra capability"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasFacility
:hasFacility rdf:type owl:ObjectProperty ;
             owl:inverseOf :isFacilityOf ;
             rdfs:domain :Organisation ;
             rdfs:range :Facility ;
             rdfs:comment "Property to connect an organization with its facility"@en ;
             rdfs:label "has facility"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasGender
:hasGender rdf:type owl:ObjectProperty ;
           owl:inverseOf :isGenderOf ;
           rdfs:domain :Person ;
           rdfs:range :Gender ;
           rdfs:comment "Property to connect a Person to its gender"@en ;
           rdfs:label "has gender"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasOrganizationalStaffRole
:hasOrganizationalStaffRole rdf:type owl:ObjectProperty ;
                            owl:inverseOf :isOrganizationalStaffRoleOf ;
                            rdfs:domain :TrainingCourse ;
                            rdfs:range :OrganisationalStaffRole ;
                            rdfs:comment "Property to connect a training course to its organizational staff roles"@en ;
                            rdfs:label "has organizational staff role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasParticipantRole
:hasParticipantRole rdf:type owl:ObjectProperty ;
                    owl:inverseOf :participatesInExercise ;
                    rdfs:domain :Exercise ;
                    rdfs:range :Role ;
                    rdfs:comment "Property linking an Exercise to the Role that participates in it"@en ;
                    rdfs:label "has participant role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasResponseAction
:hasResponseAction rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isResponseActionOf ;
                   rdfs:comment "Property to connect an Incident with the response action of a training centre"@en ;
                   rdfs:label "has response action"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasResponseActionForThreat
:hasResponseActionForThreat rdf:type owl:ObjectProperty ;
                            owl:inverseOf :isResponseActionForThreat ;
                            rdfs:domain :ThreatAgent ;
                            rdfs:range :ResponseAction ;
                            rdfs:comment "Property linking a threat agent to the response action that addresses it"@en ;
                            rdfs:label "has response action for threat"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasSOPAudience
:hasSOPAudience rdf:type owl:ObjectProperty ;
                owl:inverseOf :isSOPAudienceOf ;
                rdfs:domain :SOP ;
                rdfs:range :Audience ;
                rdfs:comment "Property that connects an SOP to its audience"@en ;
                rdfs:label "has SOP audience"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasScenarioRole
:hasScenarioRole rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isScenarioRoleOf ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :Exercise
                                             :Scenario
                                           )
                             ] ;
                 rdfs:range :ScenarioRole ;
                 rdfs:comment "Property to connect an exercise or a scenario to a scenario role"@en ;
                 rdfs:label "has scenario role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTCDiscipline
:hasTCDiscipline rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isTCDisciplineOf ;
                 rdfs:domain :TrainingCentre ;
                 rdfs:range :TCDiscipline ;
                 rdfs:comment "Property to connect a training centre to its discipline(s)"@en ;
                 rdfs:label "has Training Centre Discipline"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTCType
:hasTCType rdf:type owl:ObjectProperty ;
           owl:inverseOf :isTCTypeOf ;
           rdfs:domain :TrainingCentre ;
           rdfs:range :TCType ;
           rdfs:comment "Property to indicate the type of a training centre"@en ;
           rdfs:label "has Training centre type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTRL
:hasTRL rdf:type owl:ObjectProperty ;
        owl:inverseOf :isTRLOf ;
        rdfs:domain :Technology ;
        rdfs:range :TRLEnumeration ;
        rdfs:comment "Property to connect a technology to its TRL"@en ;
        rdfs:label "has TRL"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTrainer
:hasTrainer rdf:type owl:ObjectProperty ;
            owl:inverseOf :teachesCourse ;
            rdfs:domain :TrainingCourse ;
            rdfs:range :TrainerRole ;
            rdfs:comment "Property linking a TrainingCourse to the TrainerRole that teaches it"@en ;
            rdfs:label "has trainer"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTrainingAudience
:hasTrainingAudience rdf:type owl:ObjectProperty ;
                     owl:inverseOf :isTrainingAudienceOf ;
                     rdfs:domain :TrainingCourse ;
                     rdfs:range :Audience ;
                     rdfs:comment "Property that connects Training courses and Technology Trainings to their audience"@en ;
                     rdfs:label "has training audience"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTrainingParticipant
:hasTrainingParticipant rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isTrainingParticipantOf ;
                        rdfs:domain :TrainingCourse ;
                        rdfs:range :TrainingParticipantRole ;
                        rdfs:comment "Property to connect a training course to a participant"@en ;
                        rdfs:label "has training participant"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#includesScenario
:includesScenario rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isScenarioIncludedIn ;
                  rdfs:domain :EmergencyResponsePlan ;
                  rdfs:range :Scenario ;
                  rdfs:comment "Property to show what scenario an ERP includes"@en ;
                  rdfs:label "includes scenario"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#involvesThreat
:involvesThreat rdf:type owl:ObjectProperty ;
                owl:inverseOf :isThreatInvolvedIn ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :Incident
                                            :Scenario
                                          )
                            ] ;
                rdfs:range :ThreatAgent ;
                rdfs:comment "Property to connect an incident or a scenario to the threat agent it involves"@en ;
                rdfs:label "involves threat"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isActionRequiredBy
:isActionRequiredBy rdf:type owl:ObjectProperty ;
                    owl:inverseOf :requiresAction ;
                    rdfs:domain :ResponseAction ;
                    rdfs:range :Scenario ;
                    rdfs:comment "Property linking a ResponseAction to the Scenario that requires it"@en ;
                    rdfs:label "is action required by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isActorTypeOf
:isActorTypeOf rdf:type owl:ObjectProperty ;
               rdfs:domain :ActorType ;
               rdfs:range :Exercise ;
               rdfs:comment "Property linking an ActorType to the Exercise that uses it"@en ;
               rdfs:label "is actor type of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isAddressedBy
:isAddressedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :ThreatAgent ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( :EmergencyResponsePlan
                                          :Resource
                                        )
                          ] ;
               rdfs:comment "Property linking a ThreatAgent to the Resource or EmergencyResponsePlan that addresses it"@en ;
               rdfs:label "is addressed by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isAffiliationOf
:isAffiliationOf rdf:type owl:ObjectProperty ;
                 rdfs:domain :PersonAffiliation ;
                 rdfs:range :Person ;
                 rdfs:comment "Property linking a PersonAffiliation to the Person it belongs to"@en ;
                 rdfs:label "is affiliation of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isBasedOnIncident
:isBasedOnIncident rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isIncidentBasisFor ;
                   rdfs:domain :Scenario ;
                   rdfs:range :Incident ;
                   rdfs:comment "Property to connect a scenario to the incident its based on"@en ;
                   rdfs:label "is based on incident"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isBasedOnScenario
:isBasedOnScenario rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isScenarioBasisFor ;
                   rdfs:domain :Exercise ;
                   rdfs:range :Scenario ;
                   rdfs:comment "Property to connect an exercise to the scenario it is based"@en ;
                   rdfs:label "is based on scenario"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isCapacityOf
:isCapacityOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Capacity ;
              rdfs:range :TrainingCentre ;
              rdfs:comment "Property linking a Capacity to the TrainingCentre it belongs to"@en ;
              rdfs:label "is capacity of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isCertificateGrantedFor
:isCertificateGrantedFor rdf:type owl:ObjectProperty ;
                         rdfs:domain :Certificate ;
                         rdfs:range :TrainingCourse ;
                         rdfs:comment "Property linking a Certificate to the TrainingCourse that grants it"@en ;
                         rdfs:label "is certificate granted for"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isCertificateIssuedBy
:isCertificateIssuedBy rdf:type owl:ObjectProperty ;
                       owl:inverseOf :issuesCertificate ;
                       rdfs:domain :Certificate ;
                       rdfs:range :TrainingCentre ;
                       rdfs:comment "Property linking a Certificate to the TrainingCentre that issued it"@en ;
                       rdfs:label "is certificate issued by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isCompetenceOf
:isCompetenceOf rdf:type owl:ObjectProperty ;
                rdfs:domain :Competence ;
                rdfs:range :TrainingCentre ;
                rdfs:comment "Property linking a Competence to the TrainingCentre it belongs to"@en ;
                rdfs:label "is competence of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isCompetenceRequiredBy
:isCompetenceRequiredBy rdf:type owl:ObjectProperty ;
                        owl:inverseOf :requiresCompetence ;
                        rdfs:domain :Competence ;
                        rdfs:range [ rdf:type owl:Class ;
                                     owl:unionOf ( :Capacity
                                                   :Service
                                                 )
                                   ] ;
                        rdfs:comment "Property linking a Competence to the Capacity or Service that requires it"@en ;
                        rdfs:label "is competence required by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isDecomMethodEmployedBy
:isDecomMethodEmployedBy rdf:type owl:ObjectProperty ;
                         rdfs:domain :DecontaminationMethod ;
                         rdfs:range :DecontaminationTechnology ;
                         rdfs:comment "Property linking a DecontaminationMethod to the DecontaminationTechnology that employs it"@en ;
                         rdfs:label "is decontamination method employed by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isDomainOfUseOf
:isDomainOfUseOf rdf:type owl:ObjectProperty ;
                 rdfs:domain :DomainOfUse ;
                 rdfs:range :Technology ;
                 rdfs:comment "Property linking a DomainOfUse to the Technology it is associated with"@en ;
                 rdfs:label "is domain of use of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isERPCapabilityOf
:isERPCapabilityOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :ERPCapability ;
                   rdfs:range :EmergencyResponsePlan ;
                   rdfs:comment "Property linking an ERPCapability to the EmergencyResponsePlan it belongs to"@en ;
                   rdfs:label "is ERP capability of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isEquipmentOf
:isEquipmentOf rdf:type owl:ObjectProperty ;
               rdfs:domain :Equipment ;
               rdfs:range :Organisation ;
               rdfs:comment "Property linking an Equipment to the Organisation it belongs to"@en ;
               rdfs:label "is equipment of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isEvaluationMethodUsedBy
:isEvaluationMethodUsedBy rdf:type owl:ObjectProperty ;
                          owl:inverseOf :usesEvaluationMethod ;
                          rdfs:domain :EvaluationMethod ;
                          rdfs:range :ExerciseEvaluation ;
                          rdfs:comment "Property linking an EvaluationMethod to the ExerciseEvaluation that uses it"@en ;
                          rdfs:label "is evaluation method used by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isExerciseEvaluationOf
:isExerciseEvaluationOf rdf:type owl:ObjectProperty ;
                        rdfs:domain :ExerciseEvaluation ;
                        rdfs:range :Exercise ;
                        rdfs:comment "Property linking an ExerciseEvaluation to the Exercise it evaluates"@en ;
                        rdfs:label "is exercise evaluation of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isExerciseOrganizedBy
:isExerciseOrganizedBy rdf:type owl:ObjectProperty ;
                       owl:inverseOf :organizesExercise ;
                       rdfs:domain :Exercise ;
                       rdfs:range :TrainingCentre ;
                       rdfs:comment "Property linking an Exercise to the TrainingCentre that organizes it"@en ;
                       rdfs:label "is exercise organized by"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isExercisePhaseOf
:isExercisePhaseOf rdf:type owl:ObjectProperty ;
                   rdfs:domain :ExercisePhase ;
                   rdfs:range :Exercise ;
                   rdfs:comment "Property linking an ExercisePhase to the Exercise it belongs to"@en ;
                   rdfs:label "is exercise phase of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isExerciseTypeOf
:isExerciseTypeOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :ExerciseType ;
                  rdfs:range :Exercise ;
                  rdfs:comment "Property linking an ExerciseType to the Exercise it characterizes"@en ;
                  rdfs:label "is exercise type of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isExtraCapabilityOf
:isExtraCapabilityOf rdf:type owl:ObjectProperty ;
                     rdfs:domain :ExtraCapability ;
                     rdfs:range :TrainingCentre ;
                     rdfs:comment "Property linking an ExtraCapability to the TrainingCentre it belongs to"@en ;
                     rdfs:label "is extra capability of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isFacilityOf
:isFacilityOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Facility ;
              rdfs:range :Organisation ;
              rdfs:comment "Property linking a Facility to the Organisation it belongs to"@en ;
              rdfs:label "is facility of"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isFacilityRequiredBy
:isFacilityRequiredBy rdf:type owl:ObjectProperty ;
                      owl:inverseOf :requiresFacility ;
                      rdfs:domain :Facility ;
                      rdfs:range :Service ;
                      rdfs:comment "Property linking a Facility to the Service that requires it"@en ;
