:hasCourseFrequency rdf:type owl:DatatypeProperty ;
                    rdfs:domain :TrainingCourse ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The frequency of a training course" ;
                    rdfs:label "has course frequencye"@en .


