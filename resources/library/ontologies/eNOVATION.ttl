:hasPrinciple rdf:type owl:DatatypeProperty ;
              rdfs:domain :Technology ;
              rdfs:range xsd:string ;
              rdfs:comment "The principle of a technology (the technological background of a technology)"@en ;
              rdfs:label "has principle"@en .


