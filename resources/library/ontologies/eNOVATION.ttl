:hasPricePerCourse rdf:type owl:DatatypeProperty ;
                   rdfs:domain :TrainingCourse ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The price per course of a training course"@en ;
                   rdfs:label "has price per course"@en .


