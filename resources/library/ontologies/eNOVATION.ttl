:hasEvaluationScore rdf:type owl:DatatypeProperty ;
                    rdfs:domain :ExerciseEvaluation ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The evaluation score of an exercise as a string"@en ;
                    rdfs:label "has evaluation score"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasEvaluationdate
:hasEvaluationdate rdf:type owl:DatatypeProperty ;
                   rdfs:domain :ExerciseEvaluation ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The evaluation date of an exercise"@en ;
                   rdfs:label "has evaluation date"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasExpertise
:hasExpertise rdf:type owl:DatatypeProperty ;
              rdfs:domain :TrainerRole ;
