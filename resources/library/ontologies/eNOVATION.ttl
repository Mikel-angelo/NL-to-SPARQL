:hasLength rdf:type owl:DatatypeProperty ;
           rdfs:domain :TrainingCourse ;
           rdfs:range xsd:string ;
           rdfs:comment "The length of a training course"@en ;
           rdfs:label "has length"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:domain :Person ;
         rdfs:range xsd:string ;
         rdfs:comment "The name of a person"@en ;
         rdfs:label "has name"@en .


