:hasRegion rdf:type owl:DatatypeProperty ;
           rdfs:domain :TrainingCentre ;
           rdfs:range xsd:string ;
           rdfs:comment "Region of a training centre"@en ;
           rdfs:label "has region"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasSOPDeliveryMethod
:hasSOPDeliveryMethod rdf:type owl:DatatypeProperty ;
                      rdfs:domain :SOP ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The delivery method of an SOP"@en ;
                      rdfs:label "has SOP delivery method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasSectorAppointed
:hasSectorAppointed rdf:type owl:DatatypeProperty ;
                    rdfs:domain :TrainingCentre ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Appointed sector of a training centre"@en ;
                    rdfs:label "has sector appointed"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasSite
:hasSite rdf:type owl:DatatypeProperty ;
         rdfs:domain :Organisation ;
         rdfs:range xsd:string ;
         rdfs:comment "The site of an organisation"@en ;
         rdfs:label "has site" .


###  http://www.semanticweb.org/eNOVATION-ontology#hasSurname
:hasSurname rdf:type owl:DatatypeProperty ;
            rdfs:domain :Person ;
            rdfs:range xsd:string ;
            rdfs:comment "The full surname of a Person"@en ;
            rdfs:label "has surname"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTechnologyType
:hasTechnologyType rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Technology ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The type of a technology"@en ;
                   rdfs:label "has technology type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTotalCourseHours
:hasTotalCourseHours rdf:type owl:DatatypeProperty ;
                     rdfs:domain :TrainingCourse ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Total course hours of a training course" ;
                     rdfs:label "has total course hours"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#hasTrainingFrequency
:hasTrainingFrequency rdf:type owl:DatatypeProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( :TechnologyTraining
                                                  :TrainingCourse
                                                )
                                  ] ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Training frequency of a technology training"@en ;
                      rdfs:label "has training frequency" .


###  http://www.semanticweb.org/eNOVATION-ontology#hasYearOfEstablishment
:hasYearOfEstablishment rdf:type owl:DatatypeProperty ;
                        rdfs:domain :TrainingCentre ;
                        rdfs:range xsd:string ;
                        rdfs:comment "The year of establishment of a training centre"@en ;
                        rdfs:label "has year of establishment"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#isOfLegalForm
:isOfLegalForm rdf:type owl:DatatypeProperty ;
               rdfs:comment "The legal form of a training centre"@en ;
               rdfs:label "is of legal form"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/dc/terms/AgentClass
<http://purl.org/dc/terms/AgentClass> rdf:type owl:Class ;
                                      rdfs:subClassOf rdfs:Class .


###  http://www.semanticweb.org/eNOVATION-ontology#ActorType
:ActorType rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:oneOf ( :CivilianActor
                                             :MilitaryActor
                                             :OtherActor
                                           )
                               ] ;
           rdfs:comment "A controlled vocabulary class for pointing to the type of actor involved in a scenario role"@en ;
           rdfs:label "Actor Type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#AfterActionReviewMethod
:AfterActionReviewMethod rdf:type owl:Class ;
                         rdfs:subClassOf :EvaluationMethod ;
                         rdfs:comment "A class representing evaluation methods based on structured post-exercise reflection to identify lessons learned, strengths, and areas for improvement"@en ;
                         rdfs:label "After action review method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Audience
:Audience rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          rdfs:comment "Parent class of the different type of audiences"@en ;
          rdfs:label "Audience"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Biological
:Biological rdf:type owl:Class ;
            rdfs:subClassOf :Incident ;
            rdfs:comment "Incidents involving biological agents such as viruses, bacteria, toxins, or spores"@en ;
            rdfs:label "Biological and Toxin"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CBRNNetwork
:CBRNNetwork rdf:type owl:Class ;
             rdfs:subClassOf owl:Thing ;
             rdfs:comment "Networks, partnerships, or collaborative structures focused on CBRN preparedness, response, knowledge-sharing, or capability development"@en ;
             rdfs:label "CBRN Network"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CENStandard
:CENStandard rdf:type owl:Class ;
             rdfs:subClassOf :Standard ;
             rdfs:comment "Standards developed by the European Committee for Standardization (CEN)"@en ;
             rdfs:label "CEN Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Capacity
:Capacity rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          <http://purl.org/dc/terms/description> """Broad statements of what a centre can do or provide—think of it as the “size and reach” of its facilities and services. It can be expressed in numbers or in plain language:
Quantitative: “Can train up to 100 people per month,” “Maintains three BSL-3 labs”
Qualitative: “Offers 24/7 crisis-room support,” “Provides bespoke emergency response plan development”"""@en ;
          rdfs:comment "Broad statements describing what a centre can do or provide—capturing the scale, availability, or scope of its facilities and services. Capacities may be expressed quantitatively (e.g., “Trains up to 100 people per month,” “Operates three BSL-3 laboratories”) or qualitatively (e.g., “Provides 24/7 crisis-room support,” “Delivers customised emergency response plans”)"@en ;
          rdfs:label "Capacity"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> """Broad statements of what a centre can do or provide—think of it as the “size and reach” of its facilities and services. It can be expressed in numbers or in plain language:
Quantitative: “Can train up to 100 people per month,” “Maintains three BSL-3 labs”
Qualitative: “Offers 24/7 crisis-room support,” “Provides bespoke emergency response plan development”"""@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Certificate
:Certificate rdf:type owl:Class ;
             rdfs:subClassOf owl:Thing ;
             rdfs:comment "Documentation issued to participants or trainees confirming successful completion of a training course, exercise, or competency-based activity"@en ;
             rdfs:label "Certificate"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Chemical
:Chemical rdf:type owl:Class ;
          rdfs:subClassOf :Incident ;
          rdfs:comment "Incidents involving chemical substances, including toxic industrial chemicals or chemical warfare agents"@en ;
          rdfs:label "Chemical"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CivilExercises
:CivilExercises rdf:type owl:Class ;
                rdfs:subClassOf :Service ;
                rdfs:comment "Exercise-related services provided to civilian authorities or organisations"@en ;
                rdfs:label "Civil exercises"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CivilProtection
:CivilProtection rdf:type owl:Class ;
                 rdfs:subClassOf :Audience ;
                 rdfs:comment "An audience category representing civil protection personnel involved in emergency preparedness and disaster response"@en ;
                 rdfs:label "Civil Protection"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CivilProtectionCollaboration
:CivilProtectionCollaboration rdf:type owl:Class ;
                              rdfs:subClassOf :CollaborationService ;
                              rdfs:comment "Collaboration services involving civil protection authorities"@en ;
                              rdfs:label "Civil protection collaboration"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ClassroomsLectureHalls
:ClassroomsLectureHalls rdf:type owl:Class ;
                        rdfs:subClassOf :Facility ;
                        rdfs:comment "Indoor instructional spaces used for theoretical training, briefings, simulations, and multimedia-supported learning"@en ;
                        rdfs:label "Classroom and lecture halls"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CollaborationService
:CollaborationService rdf:type owl:Class ;
                      rdfs:subClassOf :Service ;
                      rdfs:comment "Services supporting cooperation, joint activities, or shared capabilities between the Training Centre and external partners"@en ;
                      rdfs:label "Collaboration service"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CollectiveProtectiveEquipmentCPE
:CollectiveProtectiveEquipmentCPE rdf:type owl:Class ;
                                  rdfs:subClassOf :Equipment ;
                                  rdfs:comment "Equipment designed to protect groups of individuals, typically by providing shared protection against hazardous agents"@en ;
                                  rdfs:label "Collective Protective Equipment"@en ;
                                  <http://www.w3.org/2004/02/skos/core#altLabel> "CPE"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CommandPostExerciseCPX
:CommandPostExerciseCPX rdf:type owl:Class ;
                        rdfs:subClassOf :Exercise ;
                        rdfs:comment "Exercises where staff operate from command posts to manage a simulated incident, focusing on coordination, decision-making, and information management"@en ;
                        rdfs:label "Command post exercise CPX"@en ;
                        <http://www.w3.org/2004/02/skos/core#altLabel> "CPX"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Competence
:Competence rdf:type owl:Class ;
            rdfs:subClassOf owl:Thing ;
            <http://purl.org/dc/terms/description> """The specific skills and qualifications that a centre possesses—its hands-on expertise in subject-matter areas where its personnel are certified or highly practiced, for example:
•“Collecting and handling toxin samples safely”;
•“On-site chemical detection and identification”;
•“Hospital triage procedures for CBRN incidents”."""@en ;
            rdfs:comment """The specific skills, certifications, and qualifications that a centre possesses—reflecting hands-on expertise in specialised subject areas. Examples include:
• Collecting and handling toxin samples safely
• On-site chemical detection and identification
• Hospital triage procedures for CBRN incidents"""@en ;
            rdfs:label "Competence"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "The specific skills and qualifications that a centre possesses—its hands-on expertise in subject-matter areas where its personnel are certified or highly practiced."@en ;
            <http://www.w3.org/2004/02/skos/core#example> """•“Collecting and handling toxin samples safely”;
•“On-site chemical detection and identification”;
•“Hospital triage procedures for CBRN incidents”."""@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Consumable
:Consumable rdf:type owl:Class ;
            rdfs:subClassOf :Resource ;
            rdfs:comment "Materials that are used up or require replenishment during training activities or operational responses"@en ;
            rdfs:label "Consumable"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CrisisManagers
:CrisisManagers rdf:type owl:Class ;
                rdfs:subClassOf :Audience ;
                rdfs:comment "An audience category representing individuals responsible for coordinating decision-making and response actions during crises"@en ;
                rdfs:label "Crisis Managers"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CrossBorder
:CrossBorder rdf:type owl:Class ;
             rdfs:subClassOf :Incident ;
             rdfs:comment "Incidents that involve or affect multiple countries, requiring cross-border coordination and response mechanisms"@en ;
             rdfs:label "Cross Border"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#CrossBorderCollaboration
:CrossBorderCollaboration rdf:type owl:Class ;
                          rdfs:subClassOf :CollaborationService ;
                          rdfs:comment "Collaboration services involving partners across national borders"@en ;
                          rdfs:label "Cross border collaboration"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DIMTechnology
:DIMTechnology rdf:type owl:Class ;
               rdfs:subClassOf :Technology ;
               rdfs:comment "Detection, Identification, and Monitoring technologies used to detect, characterise, or monitor hazardous agents, following DIM classification in the STACCATO taxonomy"@en ;
               rdfs:label "DIM technology"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DecisionMakers
:DecisionMakers rdf:type owl:Class ;
                rdfs:subClassOf :Audience ;
                rdfs:comment "An audience category representing senior officials with authority to make strategic decisions in crisis or emergency contexts"@en ;
                rdfs:label "Desicion Makers"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DecontaminationMethod
:DecontaminationMethod rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Class ;
                                             owl:oneOf ( :BiologicalMethod
                                                         :ChemicalMethod
                                                         :EnergyMethod
                                                         :PhysicalMethod
                                                       )
                                           ] ;
                       rdfs:subClassOf owl:Thing ;
                       rdfs:comment "A controlled vocabulary class including the methods used to neutralise, remove, or reduce hazardous agents in a CBRN context"@en ;
                       rdfs:label "Decontamination Method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DecontaminationTechnology
:DecontaminationTechnology rdf:type owl:Class ;
                           rdfs:subClassOf :Technology ;
                           rdfs:comment "Technologies used to neutralise, remove, or reduce hazardous agents, following DECON classification in the STACCATO taxonomy"@en ;
                           rdfs:label "Decontamination technology"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DecontaminationZones
:DecontaminationZones rdf:type owl:Class ;
                      rdfs:subClassOf :Facility ;
                      rdfs:comment "Areas equipped for practising or demonstrating decontamination procedures, including showers, tents, drainage systems, and related equipment"@en ;
                      rdfs:label "Decontamination zones"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#DomainOfUse
:DomainOfUse rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Class ;
                                   owl:oneOf ( :CivilUse
                                               :DualUse
                                               :MilitaryUse
                                             )
                                 ] ;
             rdfs:subClassOf owl:Thing ;
             rdfs:comment "A controlled vocabulary class indicating the operational domain in which a capability, technology, or resource is applied"@en ;
             rdfs:label "Domain of use"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ERPCapability
:ERPCapability rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :CivilProtectionCapability
                                                 :CivilianCapability
                                                 :ForensicCapability
                                                 :MilitaryCapability
                                               )
                                   ] ;
               rdfs:subClassOf owl:Thing ;
               <http://purl.org/dc/terms/description> "The capability of a TC to contact ERPs for CB/T threats. Civilian Capabilities, Military capabilities, Forensic capabilities, or Civil Protection Emergency Action Plans can be utilized to prepare these plans."@en ;
               rdfs:comment "The capability of a Training Centre to contact and coordinate with Emergency Response Plans (ERPs) in the context of chemical or biological threats. Civilian, military, forensic, or civil-protection-oriented emergency plans may be used to structure and prepare these responses"@en ;
               rdfs:label "ERP Capability"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "The capability of a TC to contact ERPs for CB/T threats. Civilian Capabilities, Military capabilities, Forensic capabilities, or Civil Protection Emergency Action Plans can be utilized to prepare these plans."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EUStandard
:EUStandard rdf:type owl:Class ;
            rdfs:subClassOf :Standard ;
            rdfs:comment "Standards, regulations, or guidelines issued by the European Union"@en ;
            rdfs:label "EU Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EarlyWarning
:EarlyWarning rdf:type owl:Class ;
              rdfs:subClassOf :ResponseAction ;
              <http://purl.org/dc/terms/description> "It declares the capability of a TC to early inform external authorities at national, or cross-border level, e.g. civil protection agencies about a threat (CB/T) provided that this TC has the relevant DIM technology to measure the respective CB/T hazard in real time with reliability."@en ;
              rdfs:comment "Declares the capability of a Training Centre to provide early notification to external authorities at national or cross-border level—such as civil protection agencies—about a CB/T threat, provided that the centre possesses the appropriate DIM technologies to measure the hazard in real time with sufficient reliability"@en ;
              rdfs:label "Early warning"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "It declares the capability of a TC to early inform external authorities at national, or cross-border level, e.g. civil protection agencies about a threat (CB/T) provided that this TC has the relevant DIM technology to measure the respective CB/T hazard in real time with reliability." .


###  http://www.semanticweb.org/eNOVATION-ontology#EarthquakeCollapseStructure
:EarthquakeCollapseStructure rdf:type owl:Class ;
                             rdfs:subClassOf :Incident ;
                             rdfs:comment "Incidents involving structural collapse or damage caused by earthquakes or similar natural hazards"@en ;
                             rdfs:label "Earthquake/ Collapse structure"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EmergencyResponsePlan
:EmergencyResponsePlan rdf:type owl:Class ;
                       rdfs:subClassOf :Service ;
                       rdfs:comment "Services contributing to the development, support, or review of emergency response plans"@en ;
                       rdfs:label "Emergency response plan"@en ;
                       <http://www.w3.org/2004/02/skos/core#altLabel> "ERP"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EnviromentalRiskAssesmentMethod
:EnviromentalRiskAssesmentMethod rdf:type owl:Class ;
                                 rdfs:subClassOf :EvaluationMethod ;
                                 rdfs:comment "A class representing evaluation methods assessing environmental risks and potential impacts related to the exercise scenario"@en ;
                                 rdfs:label "Enviromental risk assesment method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Equipment
:Equipment rdf:type owl:Class ;
           rdfs:subClassOf :Resource ;
           <http://purl.org/dc/terms/description> "Tangible physical items used in CBT/CBRN contexts (e.g., detectors, cold plasma decontamination devices, protective suits). Includes PPE (personal protective equipment, masks, gloves, uniforms, protective eyewear), Collective protective equipment (CPE) at the training centers facilities, Medical Equipment (Vaccines Antidotes related to CB/T threats)."@en ;
           rdfs:comment "Physical tools, devices, or instruments required to support training activities, exercises, or response operations"@en ;
           rdfs:label "Equipment"@en ;
           <http://www.w3.org/2004/02/skos/core#definition> "Tangible physical items used in CBT/CBRN contexts (e.g., detectors, cold plasma decontamination devices, protective suits). Includes PPE (personal protective equipment, masks, gloves, uniforms, protective eyewear), Collective protective equipment (CPE) at the training centers facilities, Medical Equipment (Vaccines Antidotes related to CB/T threats)."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EthicsConsiderationMethod
:EthicsConsiderationMethod rdf:type owl:Class ;
                           rdfs:subClassOf :EvaluationMethod ;
                           rdfs:comment "A class representing evaluation methods addressing ethical considerations such as participant safety, consent, and responsible conduct"@en ;
                           rdfs:label "Ethics consideration method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#EvaluationMethod
:EvaluationMethod rdf:type owl:Class ;
                  rdfs:subClassOf owl:Thing ;
                  rdfs:comment "A class representing the different methods used to evaluate the performance, effectiveness, or outcomes of a training exercise"@en ;
                  rdfs:label "Evaluation Method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Exercise
:Exercise rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          <http://purl.org/dc/terms/description> "The type of exercises that the Training Center is capable to organise, classified as: Tabletop, Field Exercise, Command Post Exercise, Full-scale Exercise, based on the UCPM taxonomy."@en ;
          rdfs:comment "The type of exercises that the Training Center is capable to organise, classified as: Tabletop, Field Exercise, Command Post Exercise, Full-scale Exercise, based on the UCPM taxonomy."@en ;
          rdfs:label "Exercise"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "The type of exercises that the Training Center is capable to organise, classified as: Tabletop, Field Exercise, Command Post Exercise, Full-scale Exercise, based on the UCPM taxonomy."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ExerciseEvaluation
:ExerciseEvaluation rdf:type owl:Class ;
                    rdfs:subClassOf owl:Thing ;
                    rdfs:comment "Processes and criteria used to assess the performance, outcomes, and effectiveness of a training exercise"@en ;
                    rdfs:label "Exercise Evaluation"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ExercisePhase
:ExercisePhase rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( :Conduct
                                                 :Planning
                                                 :Review
                                               )
                                   ] ;
               rdfs:subClassOf owl:Thing ;
               rdfs:comment "Phases of an exercise in which the centre has experience and can potentially contribute to exercises organised by other centres"@en ;
               rdfs:label "Exercise phase"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ExerciseType
:ExerciseType rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :CivilExercise
                                                :MilitaryExercise
                                              )
                                  ] ;
              rdfs:comment "Controlled vocabulary used to classify exercises by type, such as civil or military"@en ;
              rdfs:label "Exercise type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ExternalLaboratorySupportService
:ExternalLaboratorySupportService rdf:type owl:Class ;
                                  rdfs:subClassOf :Service ;
                                  rdfs:comment "Services provided to or received from external laboratories, such as analytical support, sample processing, or specialised testing"@en ;
                                  rdfs:label "External laboratory support service"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ExtraCapability
:ExtraCapability rdf:type owl:Class ;
                 rdfs:comment "Class representing additional capabilities offered by the centre that extend beyond its core functions or primary operational domains"@en ;
                 rdfs:label "Extra capability"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FEMAStandard
:FEMAStandard rdf:type owl:Class ;
              rdfs:subClassOf :Standard ;
              rdfs:comment "Standards or guidance documents issued by the U.S. Federal Emergency Management Agency"@en ;
              rdfs:label "FEMA Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Facility
:Facility rdf:type owl:Class ;
          <http://purl.org/dc/terms/description> "Physical infrastructure and resources that the TC owns, specifically designed to support training, exercises, and simulations related to hazardous incidents, e.g. classrooms and multimedia tools, simulation zones /training fields, or Specialized Infrastructure, e.g. Decontamination units (showers, tents), or containment labs or mock labs, or CBRN protective gear storage and dressing areas, as well as Command and Control Simulation Rooms."@en ;
          rdfs:comment "Physical infrastructure and resources owned by the Training Centre that support training, exercises, and simulations related to hazardous incidents. Examples include classrooms and multimedia tools, simulation zones or training fields, specialised infrastructure such as decontamination units (showers, tents), containment or mock laboratories, CBRN protective gear storage and dressing areas, and command-and-control simulation rooms"@en ;
          rdfs:label "Facility"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "Physical infrastructure and resources that the TC owns, specifically designed to support training, exercises, and simulations related to hazardous incidents, e.g. classrooms and multimedia tools, simulation zones /training fields, or Specialized Infrastructure, e.g. Decontamination units (showers, tents), or containment labs or mock labs, or CBRN protective gear storage and dressing areas, as well as Command and Control Simulation Rooms."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FieldExercise
:FieldExercise rdf:type owl:Class ;
               rdfs:subClassOf :Exercise ;
               rdfs:comment "Exercises conducted in real operational environments, emphasizing practical response actions, deployment of resources, and on-site coordination"@en ;
               rdfs:label "Field exercise"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FieldExerciseAreas
:FieldExerciseAreas rdf:type owl:Class ;
                    rdfs:subClassOf :Facility ;
                    rdfs:comment "Outdoor training grounds or operational zones used for practical, scenario-based exercises and hands-on response activities"@en ;
                    rdfs:label "Field exercise areas"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FireExplosion
:FireExplosion rdf:type owl:Class ;
               rdfs:subClassOf :Incident ;
               rdfs:comment "Incidents involving fires, explosions, or related combustion hazards"@en ;
               rdfs:label "Fire/ Explosion"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FireRescueServices
:FireRescueServices rdf:type owl:Class ;
                    rdfs:subClassOf :Audience ;
                    rdfs:comment "An audience category representing fire and rescue service personnel engaged in emergency response and incident management"@en ;
                    rdfs:label "Fire Rescue Services"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FirstResponders
:FirstResponders rdf:type owl:Class ;
                 rdfs:subClassOf :Audience ;
                 rdfs:comment "An audience category representing frontline emergency responders directly involved in initial crisis operations"@en ;
                 rdfs:label "First Responders"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#FullScaleExerciseFSX
:FullScaleExerciseFSX rdf:type owl:Class ;
                      rdfs:subClassOf :Exercise ;
                      rdfs:comment "Exercises involving full deployment of personnel, equipment, and infrastructure to simulate a highly realistic emergency response"@en ;
                      rdfs:label "Full scale exercise FSX"@en ;
                      <http://www.w3.org/2004/02/skos/core#altLabel> "FSX"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Gender
:Gender rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :Female
                                          :Male
                                          :OtherGender
                                        )
                            ] ;
        rdfs:comment "Controlled vocabulary class to represent the different genders"@en ;
        rdfs:label "Gender"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#HealthCrisis
:HealthCrisis rdf:type owl:Class ;
              rdfs:subClassOf :Incident ;
              rdfs:comment "Incidents involving widespread public health emergencies, such as epidemics, pandemics, or mass-casualty medical crises"@en ;
              rdfs:label "Health crisis"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#HealthHospitalMedicalPersonnel
:HealthHospitalMedicalPersonnel rdf:type owl:Class ;
                                rdfs:subClassOf :Audience ;
                                rdfs:comment "An audience category representing medical, hospital, and healthcare staff involved in emergency care, crisis response, or public health management"@en ;
                                rdfs:label "Health Hospital Medical Personnel"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ISOStandard
:ISOStandard rdf:type owl:Class ;
             rdfs:subClassOf :Standard ;
             rdfs:comment "International standards published by the International Organization for Standardization (ISO)"@en ;
             rdfs:label "ISO Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          <http://purl.org/dc/terms/description> "A structured representation of a training exercise or simulated incident (“Chemical spill near a water supply,” “Biotoxin in a stadium event,” “Cross-border CB threat,” etc.). It is correlated with the respective CB/T threat, and hence with the specific simulated scenario of the exercise which can be organised by the TC, e.g.  chemical spill at an airport."@en ;
          rdfs:comment "A structured description of a hazardous event used as the basis for a training exercise or simulated scenario. Incidents are linked to specific CB/T threats and define the context of the exercise (e.g., chemical spill at an airport, biotoxin release at a stadium, cross-border threat)"@en ;
          rdfs:label "Incident"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "A structured representation of a training exercise or simulated incident (“Chemical spill near a water supply,” “Biotoxin in a stadium event,” “Cross-border CB threat,” etc.). It is correlated with the respective CB/T threat, and hence with the specific simulated scenario of the exercise which can be organised by the TC, e.g.  chemical spill at an airport."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#InnovativeTechnologiesTraining
:InnovativeTechnologiesTraining rdf:type owl:Class ;
                                rdfs:subClassOf :TechnologyTraining ;
                                rdfs:comment "Training courses focused on emerging or advanced technologies applied to CBRN or emergency-management contexts"@en ;
                                rdfs:label "Innovative technologies training"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#InternationalOrganisations
:InternationalOrganisations rdf:type owl:Class ;
                            rdfs:subClassOf :Audience ;
                            rdfs:comment "An audience category representing international bodies and agencies participating in crisis management, coordination, or support activities"@en ;
                            rdfs:label "International Organsations"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#JointCivilMilitaryExercises
:JointCivilMilitaryExercises rdf:type owl:Class ;
                             rdfs:subClassOf :Service ;
                             rdfs:comment "Services supporting exercises conducted jointly between civilian and military organisations"@en ;
                             rdfs:label "Joint civil military exercises"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#LiveAgentTrainingRanges
:LiveAgentTrainingRanges rdf:type owl:Class ;
                         rdfs:subClassOf :Facility ;
                         rdfs:comment "Specialised, controlled areas where training with live chemical, biological, or radiological agents can be safely conducted under authorised conditions"@en ;
                         rdfs:label "Live-Agent training ranges"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MedicalCBTTraining
:MedicalCBTTraining rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:oneOf ( :DecontaminationProceduresTrainingCapability
                                                      :MedicalCBTTrainingToDoctors
                                                      :MedicalCBTTrainingToMilitary
                                                      :VictimsTreatmentProtocolsTrainingCapability
                                                    )
                                        ] ;
                    rdfs:subClassOf :TrainingCourse ;
                    rdfs:comment "Training courses focused on medical aspects of chemical, biological, or toxin (CB/T) incident management"@en ;
                    rdfs:label "Medical CBT training"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MedicalEquipment
:MedicalEquipment rdf:type owl:Class ;
                  rdfs:subClassOf :Equipment ;
                  rdfs:comment "Equipment used to provide medical care, monitoring, or support during training activities or emergency scenarios"@en ;
                  rdfs:label "Medical Equipment"@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "Vaccines, Antidotes"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MilitaryDefenceExperts
:MilitaryDefenceExperts rdf:type owl:Class ;
                        rdfs:subClassOf :Audience ;
                        rdfs:comment "An audience category representing defence and military personnel contributing expertise to crisis preparedness or operational response"@en ;
                        rdfs:label "Military Defence Experts"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MilitaryExercises
:MilitaryExercises rdf:type owl:Class ;
                   rdfs:subClassOf :Service ;
                   rdfs:comment "Exercise-related services provided to military authorities or defence organisations"@en ;
                   rdfs:label "Military exercises"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MilitaryStandard
:MilitaryStandard rdf:type owl:Class ;
                  rdfs:subClassOf :Standard ;
                  rdfs:comment "Standards issued by military or defence authorities"@en ;
                  rdfs:label "Military Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#MultiAgencyCollaboration
:MultiAgencyCollaboration rdf:type owl:Class ;
                          rdfs:subClassOf :CollaborationService ;
                          rdfs:comment "Collaboration services involving multiple agencies working jointly in training or preparedness activities"@en ;
                          rdfs:label "Multi agency collaboration"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#NATOStandard
:NATOStandard rdf:type owl:Class ;
              rdfs:subClassOf :Standard ;
              rdfs:comment "Standards published by NATO, including STANAG documents and related interoperability requirements"@en ;
              rdfs:label "NATO Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#National
:National rdf:type owl:Class ;
          rdfs:subClassOf :Standard ;
          rdfs:comment "National-level standards or regulations issued by governmental authorities within a specific country"@en ;
          rdfs:label "National"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#NationalMunicipalRegionalAuthorities
:NationalMunicipalRegionalAuthorities rdf:type owl:Class ;
                                      rdfs:subClassOf :Audience ;
                                      rdfs:comment "An audience category representing public authorities at national, municipal, or regional level involved in governance, planning, or crisis management"@en ;
                                      rdfs:label "National Municipal Regional Authorities"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ObservationMethod
:ObservationMethod rdf:type owl:Class ;
                   rdfs:subClassOf :EvaluationMethod ;
                   rdfs:comment "A class representing evaluation methods based on direct observation of participant actions, decisions, and interactions during the exercise"@en ;
                   rdfs:label "Observation method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Organisation
:Organisation rdf:type owl:Class ;
              rdfs:subClassOf owl:Thing ;
              rdfs:comment "Formal institutions or agencies engaged in training, preparedness, response, or governance activities related to hazardous incidents"@en ;
              rdfs:label "Organisation"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#OrganisationalStaffRole
:OrganisationalStaffRole rdf:type owl:Class ;
                         rdfs:subClassOf :Role ;
                         rdfs:comment "Roles held by personnel contributing to the organisational or administrative functions of a training or emergency-management context"@en ;
                         rdfs:label "Organizational staff role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#OrganisationalStakeholder
:OrganisationalStakeholder rdf:type owl:Class ;
                           owl:equivalentClass [ rdf:type owl:Class ;
                                                 owl:oneOf ( :CivilProtectionAgency
                                                             :EnviromentalProtectionAgency
                                                             :LawEnforcementAgency
                                                             :LocalHealthAuthoritiesAgencies
                                                             :MinistryOfDefence
                                                             :MinistryOfInternalAffairs
                                                             :NationalSecurityAgent
                                                           )
                                               ] ;
                           rdfs:subClassOf :Organisation ;
                           <http://purl.org/dc/terms/description> """Any institution or agency that has a direct interest in, supports, or is affected by the Training entre’s activities. These are the bodies the TCs routinely engage with or serve, for example:
•Ministries: Health, Defence, Interior;
•Agencies: Civil Protection, Environmental Protection, National Security/Intelligence;
•Public Authorities: Regional or Local Health Departments, Fire & Rescue Services, Police Departments (including specialized tactical units);
•Partners: Hospitals, Research Institutes, Private-sector Security Providers."""@en ;
                           rdfs:comment "Institutions or agencies that have a direct interest in, support, or are affected by the Training Centre’s activities. These include bodies with which the centre routinely engages or collaborates, such as ministries (Health, Defence, Interior), civil protection or environmental agencies, national security and intelligence services, regional or local authorities, fire and rescue services, police departments, hospitals, research institutes, and private-sector security providers"@en ;
                           rdfs:label "Organizational stakeholder"@en ;
                           <http://www.w3.org/2004/02/skos/core#definition> """Any institution or agency that has a direct interest in, supports, or is affected by the Training entre’s activities. These are the bodies the TCs routinely engage with or serve, for example:
•Ministries: Health, Defence, Interior;
•Agencies: Civil Protection, Environmental Protection, National Security/Intelligence;
•Public Authorities: Regional or Local Health Departments, Fire & Rescue Services, Police Departments (including specialized tactical units);
•Partners: Hospitals, Research Institutes, Private-sector Security Providers."""@en .


###  http://www.semanticweb.org/eNOVATION-ontology#OtherService
:OtherService rdf:type owl:Class ;
              rdfs:subClassOf :Service ;
              rdfs:comment "Additional services offered by the Training Centre that do not fall into predefined categories"@en ;
              rdfs:label "Other service"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PPEStorageLogisticsSupportAreas
:PPEStorageLogisticsSupportAreas rdf:type owl:Class ;
                                 rdfs:subClassOf :Facility ;
                                 rdfs:comment "Spaces dedicated to storing, maintaining, and preparing personal protective equipment and associated logistical materials for training or exercise deployment"@en ;
                                 rdfs:label "PPE storage and logistics support areas"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PerfomanceMetricsMethod
:PerfomanceMetricsMethod rdf:type owl:Class ;
                         rdfs:subClassOf :EvaluationMethod ;
                         rdfs:comment "A class representing evaluation methods that use predefined indicators or metrics to assess performance and exercise effectiveness"@en ;
                         rdfs:label "Perfomance metrics method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Person
:Person rdf:type owl:Class ;
        rdfs:comment "Class representing a person or a group"@en ;
        rdfs:label "Person or Group"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PersonAffiliation
:PersonAffiliation rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:oneOf ( :CivilProtectionAffiliation
                                                     :CivilianAffiliation
                                                     :GraduateAffiliation
                                                     :HybridAffiliation
                                                     :MilitaryAffiliation
                                                   )
                                       ] ;
                   rdfs:comment "Controlled vocabulary class to indicate the affiliation of a person"@en ;
                   rdfs:label "Person or Group Affiliation"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PersonalProtectiveEquipmentPPE
:PersonalProtectiveEquipmentPPE rdf:type owl:Class ;
                                rdfs:subClassOf :Equipment ;
                                rdfs:comment "Equipment worn by individuals to protect against exposure to hazardous agents during training or operational tasks"@en ;
                                rdfs:label "Personal Protective Equipment"@en ;
                                <http://www.w3.org/2004/02/skos/core#altLabel> "PPE"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Personnel
:Personnel rdf:type owl:Class ;
           rdfs:subClassOf :Resource ;
           rdfs:comment "Human resources contributing skills, expertise, or operational capacity in training or response contexts"@en ;
           rdfs:label "Personnel"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PoliceLawEnforcementAgencies
:PoliceLawEnforcementAgencies rdf:type owl:Class ;
                              rdfs:subClassOf :Audience ;
                              rdfs:comment "An audience category representing police and law-enforcement personnel responsible for maintaining security and supporting crisis response"@en ;
                              rdfs:label "Police law enforcement agencies"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#PrivateCompanies
:PrivateCompanies rdf:type owl:Class ;
                  rdfs:subClassOf :Audience ;
                  rdfs:comment "An audience category representing private-sector organisations contributing to crisis preparedness, support activities, or infrastructure operations"@en ;
                  rdfs:label "Private Companies"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#RadiologicalAndNuclear
:RadiologicalAndNuclear rdf:type owl:Class ;
                        rdfs:subClassOf :Incident ;
                        rdfs:comment "Incidents involving radiological or nuclear materials, including accidental releases or intentional dispersal events"@en ;
                        rdfs:label "Radiological and Nuclear"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Resource
:Resource rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          <http://purl.org/dc/terms/description> "Personnel, equipment, or consumables needed for a scenario or incident."@en ;
          rdfs:comment "Personnel, equipment, infrastructure, or consumables required for executing a scenario, training activity, or operational response"@en ;
          rdfs:label "Resource"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "Personnel, equipment, or consumables needed for a scenario or incident."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ResponseAction
:ResponseAction rdf:type owl:Class ;
                rdfs:subClassOf owl:Thing ;
                rdfs:comment "Actions undertaken to manage, mitigate, or control the consequences of an incident during a training exercise or operational response"@en ;
                rdfs:label "Response action"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Role
:Role rdf:type owl:Class ;
      rdfs:subClassOf :Person ;
      rdfs:comment "Functions or positions that a person may hold within training, organisational, or exercise contexts"@en ;
      rdfs:label "Role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#SOP
:SOP rdf:type owl:Class ;
     rdfs:subClassOf owl:Thing ;
     <http://purl.org/dc/terms/description> "The Standard Operating Procedures relevant to Seach and Rescue, CBRN Triage and Response etc. which are used by the Training Centers for training of the First Responders."@en ;
     rdfs:comment "The Standard Operating Procedures relevant to Seach and Rescue, CBRN Triage and Response etc. which are used by the Training Centers for training of the First Responders."@en ;
     rdfs:label "SOP"@en ;
     <http://www.w3.org/2004/02/skos/core#altLabel> "Standard Operating Procedure"@en ;
     <http://www.w3.org/2004/02/skos/core#definition> "The Standard Operating Procedures relevant to Seach and Rescue, CBRN Triage and Response etc. which are used by the Training Centers for training of the First Responders."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#SafetySecurityPlanMethod
:SafetySecurityPlanMethod rdf:type owl:Class ;
                          rdfs:subClassOf :EvaluationMethod ;
                          rdfs:comment "A class representing evaluation methods that review the adequacy and implementation of safety and security measures within the exercise"@en ;
                          rdfs:label "Safety security plan method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Scenario
:Scenario rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          <http://purl.org/dc/terms/description> "A structured representation of a training exercise or simulated incident (“Chemical spill near a water supply,” “Biotoxin in a stadium event,” “Cross-border CB threat,” etc.)."@en ;
          rdfs:comment "A structured representation of a training exercise or simulated incident (e.g., “Chemical spill near a water supply,” “Biotoxin release during a stadium event,” “Cross-border CB threat”)"@en ;
          rdfs:label "Scenario"@en ;
          <http://www.w3.org/2004/02/skos/core#definition> "A structured representation of a training exercise or simulated incident (“Chemical spill near a water supply,” “Biotoxin in a stadium event,” “Cross-border CB threat,” etc.)."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ScenarioRole
:ScenarioRole rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :CommandStaff
                                                :ControllerEXCON
                                                :Evaluator
                                                :Facilitator
                                                :FirstResponder
                                                :MedicalPersonnel
                                                :Observer
                                                :RolePlayer
                                                :SupportTeam
                                              )
                                  ] ;
              rdfs:subClassOf owl:Thing ;
              rdfs:comment "Roles defining the function or responsibilities of actors within a scenario"@en ;
              rdfs:label "Scenario role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ScenarioSpecificCriteriaMethod
:ScenarioSpecificCriteriaMethod rdf:type owl:Class ;
                                rdfs:subClassOf :EvaluationMethod ;
                                rdfs:comment "A class representing evaluation methods that apply criteria tailored to the specific scenario, objectives, or threat conditions of the exercise"@en ;
                                rdfs:label "Scenario specific criteria method"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#SecondResponders
:SecondResponders rdf:type owl:Class ;
                  rdfs:subClassOf :Audience ;
                  rdfs:comment "An audience category representing individuals or organisations providing follow-up support after initial emergency response actions"@en ;
                  rdfs:label "Second Responders"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Service
:Service rdf:type owl:Class ;
         rdfs:subClassOf owl:Thing ;
         rdfs:comment "Activities or support functions offered by the Training Centre to external partners, authorities, or other centres"@en ;
         rdfs:label "Service"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#SimulationRooms
:SimulationRooms rdf:type owl:Class ;
                 rdfs:subClassOf :Facility ;
                 rdfs:comment "Indoor environments equipped with tools, software, or mock setups to simulate command-and-control conditions, incident rooms, or realistic operational scenarios"@en ;
                 rdfs:label "Simulation rooms"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Standard
:Standard rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing ;
          rdfs:comment "Norms, guidelines, or technical requirements that define procedures, quality criteria, or operational expectations relevant to training, preparedness, or emergency response"@en ;
          rdfs:label "Standard"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Students
:Students rdf:type owl:Class ;
          rdfs:subClassOf :Audience ;
          rdfs:comment "An audience category representing learners participating in training, educational programmes, or awareness activities related to crisis management"@en ;
          rdfs:label "Students"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TCDiscipline
:TCDiscipline rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( :B
                                                :C
                                                :RN
                                              )
                                  ] ;
              rdfs:comment "Controlled vocabulary class of the different {C,B,RN} disciplines"@en ;
              rdfs:label "Training Centre Discipline"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TCType
:TCType rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :CivilianType
                                          :JointActivityType
                                          :MilitaryType
                                        )
                            ] ;
        rdfs:comment "Controlled vocabulary of the different types of a training centre"@en ;
        rdfs:label "Training Centre Type"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TRLEnumeration
:TRLEnumeration rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :TRL_1
                                                  :TRL_2
                                                  :TRL_3
                                                  :TRL_4
                                                  :TRL_5
                                                  :TRL_6
                                                  :TRL_7
                                                  :TRL_8
                                                  :TRL_9
                                                )
                                    ] ;
                rdfs:subClassOf owl:Thing ;
                rdfs:comment "Class representing the TRL readiness of a technology"@en ;
                rdfs:label "TRL enumeration"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TableTopExerciseTTX
:TableTopExerciseTTX rdf:type owl:Class ;
                     rdfs:subClassOf :Exercise ;
                     rdfs:comment "Discussion-based exercises held in an indoor setting, where participants explore scenarios, roles, and decisions without physical deployment"@en ;
                     rdfs:label "Table top exercise TTX"@en ;
                     <http://www.w3.org/2004/02/skos/core#altLabel> "TTX"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Technology
:Technology rdf:type owl:Class ;
            rdfs:subClassOf :Resource ;
            <http://purl.org/dc/terms/description> "Technologies are divided into two basic categories: Detection, Identification, Monitoring (DIM), and Decontamination (DECON). These technologies have type (e.g. spectrometry) and principle of operation (e.g. Tandem Mass Spectrometry MS/MS) based on the STACCATO taxonomy. Technologies are provided by the type of threat (chemical, biological, toxin); their TRL is also available."@en ;
            rdfs:comment "Technologies used in CBRN contexts, classified into two main categories: Detection–Identification–Monitoring (DIM) and Decontamination (DECON). Each technology is characterised by its type (e.g., spectrometry) and its principle of operation (e.g., Tandem Mass Spectrometry MS/MS), following the STACCATO taxonomy. Technologies are linked to the relevant threat type (chemical, biological, toxin) and include information such as Technology Readiness Level (TRL)"@en ;
            rdfs:label "Technology"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "Technologies are divided into two basic categories: Detection, Identification, Monitoring (DIM), and Decontamination (DECON). These technologies have type (e.g. spectrometry) and principle of operation (e.g. Tandem Mass Spectrometry MS/MS) based on the STACCATO taxonomy. Technologies are provided by the type of threat (chemical, biological, toxin); their TRL is also available."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TechnologyOperators
:TechnologyOperators rdf:type owl:Class ;
                     rdfs:subClassOf :Audience ;
                     rdfs:comment "An audience category representing personnel responsible for operating technical systems, tools, or equipment in training or crisis scenarios"@en ;
                     rdfs:label "Technology operators"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TechnologyTraining
:TechnologyTraining rdf:type owl:Class ;
                    rdfs:subClassOf :TrainingCourse ;
                    rdfs:comment "Training courses focused on the use, operation, or understanding of technologies relevant to CBRN preparedness or response"@en ;
                    rdfs:label "Technology Training"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#ThreatAgent
:ThreatAgent rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Class ;
                                   owl:oneOf ( :BiologicalThreat
                                               :ChemicalThreat
                                               :RNThreat
                                               :ToxinThreat
                                             )
                                 ] ;
             rdfs:subClassOf owl:Thing ;
             rdfs:comment "Categories of hazardous agents that may be involved in an incident or training scenario, used to classify CBRN and toxin-related threats"@en ;
             rdfs:label "Threat agent"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TraineesTrainersExchange
:TraineesTrainersExchange rdf:type owl:Class ;
                          rdfs:subClassOf :Service ;
                          rdfs:comment "Services enabling the exchange of trainees or trainers between centres or partner organisations"@en ;
                          rdfs:label "Trainees trainers exchange"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TrainerRole
:TrainerRole rdf:type owl:Class ;
             rdfs:subClassOf :Role ;
             rdfs:comment "Roles held by individuals responsible for delivering, guiding, or supervising training activities"@en ;
             rdfs:label "Trainer role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TrainingCentre
:TrainingCentre rdf:type owl:Class ;
                rdfs:subClassOf :Organisation ;
                rdfs:comment "Organisations that design, deliver, or host training activities, exercises, and capacity-building programmes related to hazardous incidents or CBRN preparedness"@en ;
                rdfs:label "Training centre"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TrainingCourse
:TrainingCourse rdf:type owl:Class ;
                rdfs:subClassOf owl:Thing ;
                rdfs:comment "Structured training offerings provided by the Training Centre to build knowledge, skills, or operational capabilities"@en ;
                rdfs:label "Training course"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TrainingMethod
:TrainingMethod rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:oneOf ( :AR_VRBasedSessions
                                                  :ClassroomBasedLearning
                                                  :ELearning
                                                  :GroupDiscussion
                                                )
                                    ] ;
                rdfs:subClassOf owl:Thing ;
                <http://purl.org/dc/terms/description> "Technique or approach used to deliver a lesson or practice a skill (classroom sessions, group discussions, VR simulations, etc.)."@en ;
                rdfs:comment "Technique or approach used to deliver a lesson or practice a skill (classroom sessions, group discussions, VR simulations, etc.)."@en ;
                rdfs:label "Training method"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "Technique or approach used to deliver a lesson or practice a skill (classroom sessions, group discussions, VR simulations, etc.)."@en .


###  http://www.semanticweb.org/eNOVATION-ontology#TrainingParticipantRole
:TrainingParticipantRole rdf:type owl:Class ;
                         rdfs:subClassOf :Role ;
                         rdfs:comment "Roles held by individuals taking part in training activities, exercises, or capacity-building sessions"@en ;
                         rdfs:label "Training participant role"@en .


###  http://www.semanticweb.org/eNOVATION-ontology#Vehicle
:Vehicle rdf:type owl:Class ;
         rdfs:subClassOf :Resource ;
         rdfs:comment "Transport assets used to support the movement of personnel, equipment, or materials in training or operational scenarios"@en ;
         rdfs:label "Vehicle"@en .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#List
rdf:List rdf:type owl:Class .


###  http://www.w3.org/2000/01/rdf-schema#Class
rdfs:Class rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Collection
<http://www.w3.org/2004/02/skos/core#Collection> rdf:type owl:Class ;
                                                 owl:disjointWith <http://www.w3.org/2004/02/skos/core#Concept> ,
                                                                  <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "Collection"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A meaningful collection of concepts."@en ;
                                                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Labelled collections can be used where you would like a set of concepts to be displayed under a 'node label' in the hierarchy."@en .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class ;
                                              owl:disjointWith <http://www.w3.org/2004/02/skos/core#ConceptScheme> ,
                                                               <http://www.w3.org/2004/02/skos/core#OrderedCollection> ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              rdfs:label "Concept"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "An idea or notion; a unit of thought."@en .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class ;
                                                    owl:disjointWith <http://www.w3.org/2004/02/skos/core#OrderedCollection> ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                    rdfs:label "Concept Scheme"@en ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "A set of concepts, optionally including statements about semantic relationships between those concepts."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#example> "Thesauri, classification schemes, subject heading lists, taxonomies, 'folksonomies', and other types of controlled vocabulary are all examples of concept schemes. Concept schemes are also embedded in glossaries and terminologies."@en ;
                                                    <http://www.w3.org/2004/02/skos/core#scopeNote> "A concept scheme may be defined to include concepts from different sources."@en .


###  http://www.w3.org/2004/02/skos/core#OrderedCollection
<http://www.w3.org/2004/02/skos/core#OrderedCollection> rdf:type owl:Class ;
                                                        rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Collection> ;
                                                        rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                        rdfs:label "Ordered Collection"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "An ordered collection of concepts, where both the grouping and the ordering are meaningful."@en ;
                                                        <http://www.w3.org/2004/02/skos/core#scopeNote> "Ordered collections can be used where you would like a set of concepts to be displayed in a specific order, and optionally under a 'node label'."@en .


