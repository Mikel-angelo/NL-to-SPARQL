:hasOwnership rdf:type owl:DatatypeProperty ;
              rdfs:domain :TrainingCentre ;
              rdfs:range xsd:string ;
              rdfs:comment "The ownership of a training centre"@en ;
              rdfs:label "has ownership"@en .


